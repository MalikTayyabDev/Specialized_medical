{
  "name": "gatsby-starter-minimal",
  "version": "1.0.0",
  "private": true,
  "description": "A Gatsby starter with no plugins and a single welcome page.",
  "author": "Laurie Barth",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "predevelop": "node scripts/sync-static-site-assets.mjs",
    "develop": "gatsby develop",
    "prestart": "node scripts/sync-static-site-assets.mjs",
    "start": "gatsby develop",
    "prebuild": "node scripts/sync-static-site-assets.mjs && node scripts/verify-static-assets.mjs",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "sync-assets": "node scripts/sync-static-site-assets.mjs"
  },
  "license": "0BSD",
  "dependencies": {
    "gatsby": "^5.14.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
